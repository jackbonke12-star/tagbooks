# Find both values in Supabase: Project Settings -> API (Project URL and anon/public key)
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Shared PIN gate (server-only). Set this and the whole UI + printer API require
# the PIN. MUST NOT be a NEXT_PUBLIC var. Leave blank to disable the gate.
APP_PIN=

# 3D Printer (Bambu Lab) - set these in Vercel once the local agent's tunnel
# URL exists. Leave blank locally unless you are wiring up the printer page.
# BAMBU_AGENT_URL must be the public tunnel URL pointing at local-agent.
# BAMBU_AGENT_SECRET must equal the agent's AGENT_SHARED_SECRET.
BAMBU_AGENT_URL=
BAMBU_AGENT_SECRET=
